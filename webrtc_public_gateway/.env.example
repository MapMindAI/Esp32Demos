PUBLIC_FQDN=webrtc.example.com

# Janus image selector.
# Default is amd64-only image:
#   canyan/janus-gateway:latest
# For ARM64 hosts, set for example:
#   JANUS_IMAGE=sucwangsr/janus-webrtc-gateway-docker:latest
JANUS_IMAGE=canyan/janus-gateway:latest

# Use the public IPv4 of your Linux server when Janus is behind NAT.
# If Janus runs on a host with public IP directly, keep it equal to that address.
JANUS_PUBLIC_IP=203.0.113.10

# Used by web client to join VideoRoom.
JANUS_ROOM_ID=1234
JANUS_ROOM_PIN=CHANGE_ME_ROOM_PIN

# Optional: set when Janus token auth is enabled.
JANUS_VIEWER_TOKEN=

# ORB-SLAM3 bridge settings (used by slam-server).
# Put your ORB-SLAM3 vocabulary and camera YAML under SLAM_DATA_DIR.
# Example layout:
#   ./slam_data/Vocabulary/ORBvoc.txt
#   ./slam_data/config/monocular.yaml
SLAM_DATA_DIR=./slam_data
SLAM_VOCAB_PATH=/opt/orbslam/Vocabulary/ORBvoc.txt
SLAM_SETTINGS_PATH=/opt/orbslam/config/monocular.yaml
SLAM_SENSOR=MONOCULAR
SLAM_MAX_TRAJECTORY_POINTS=3000
SLAM_MAP_SAMPLE_STRIDE=4
SLAM_MAX_MAP_POINTS=4000
