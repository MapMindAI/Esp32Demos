# Local functional testing:
# open http://localhost:8080 on host.
:8080 {
  encode zstd gzip

  root * /srv/web
  file_server

  reverse_proxy /janus* 127.0.0.1:8088
  reverse_proxy /janus-ws* 127.0.0.1:8188

  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}
